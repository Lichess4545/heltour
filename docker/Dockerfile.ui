# syntax=docker/dockerfile:1.7

# ---- builder ---------------------------------------------------------------
FROM oven/bun:1.1.38 AS builder

ARG GITHUB_SHORT_SHA=unknown

WORKDIR /workspace

# Workspace manifests first so install can be cached independently of source.
COPY frontend/package.json ./frontend/
COPY frontend/api-client/package.json ./frontend/api-client/
COPY frontend/ui/package.json ./frontend/ui/

RUN cd frontend && bun install --frozen-lockfile || bun install

# OpenAPI schema is generated by the Python build inside `litour-base`
# (see `docker/Dockerfile.base`). Pull it from that build context so the
# UI image stays self-contained and doesn't require a host-side
# pre-step (the file is gitignored, so it isn't in the checkout).
COPY --from=base /app/openapi.json ./openapi.json

# Now bring in the rest of the frontend sources.
COPY frontend ./frontend

# Build the api-client first (so workspace-resolved imports have JS to load).
RUN cd frontend/api-client && bun run generate && bun run build

# Build the Next.js app in standalone mode.
ENV NEXT_TELEMETRY_DISABLED=1
ENV LITOUR_UI_BASE_PATH=/v2
ENV NEXT_PUBLIC_LITOUR_API_URL=/v2/api
RUN cd frontend/ui && bun run build

# ---- runtime --------------------------------------------------------------
FROM oven/bun:1.1.38-slim AS runtime

ARG GITHUB_SHORT_SHA=unknown

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    LITOUR_UI_BASE_PATH=/v2 \
    NEXT_PUBLIC_LITOUR_API_URL=/v2/api \
    HELTOUR_VERSION=${GITHUB_SHORT_SHA}

# Next.js standalone output bundles only the runtime files needed.
COPY --from=builder /workspace/frontend/ui/.next/standalone ./
COPY --from=builder /workspace/frontend/ui/.next/static ./frontend/ui/.next/static
COPY --from=builder /workspace/frontend/ui/public ./frontend/ui/public

EXPOSE 3000

CMD ["bun", "frontend/ui/server.js"]
