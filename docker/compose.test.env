# Test-only environment for docker/compose.test.yml.
# Dummy secrets: fine to commit, never use these values anywhere real.
# See docs/testing-the-infrastructure.md "Testing the containers locally".

SECRET_KEY=docker-test-harness-not-a-real-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,web,caddy
CSRF_TRUSTED_ORIGINS=http://localhost:8090

DATABASE_URL=postgresql://heltour_test:heltour_test_password@postgres:5432/heltour_test
REDIS_URL=redis://redis:6379/1
BROKER_URL=redis://redis:6379/1

HELTOUR_ENV=dev
HELTOUR_VERSION=docker-test
