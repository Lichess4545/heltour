# Django Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,apiworker,staging.lichess4545.com,staging.lichess4545.tv
CSRF_TRUSTED_ORIGINS=https://staging.lichess4545.com,https://staging.lichess4545.tv

# Redis Configuration (db 1 for both cache and celery broker, heltour convention)
REDIS_URL=redis://redis:6379/1
BROKER_URL=redis://redis:6379/1

# Email Configuration
# Unverified placeholder carried from deploy/prod/stack.env (AWS SES eu-west-3) — confirm
# against heltour's actual mail relay before using this stack for a real deploy.
EMAIL_HOST=email-smtp.eu-west-3.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Application Configuration
# heltour/settings.py:51 reads STAGING = env("HELTOUR_ENV") == "stage" (literal string
# "stage", not "staging") — this must stay "stage" or settings.STAGING silently goes
# False and staging loses the admin/ratings-update gating that flag controls.
HELTOUR_ENV=stage
API_WORKER_HOST=http://apiworker:8000
