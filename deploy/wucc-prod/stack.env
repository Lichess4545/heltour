# Django Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,apiworker,wucc.palamedes.lichess.app
CSRF_TRUSTED_ORIGINS=https://wucc.palamedes.lichess.app

# Redis Configuration
REDIS_URL=redis://redis:6379/0
BROKER_URL=redis://redis:6379/1

# Email Configuration
EMAIL_HOST=email-smtp.eu-west-3.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
SERVER_EMAIL=noreply@lichess.org
DEFAULT_FROM_EMAIL=noreply@lichess.org

# Static and Media Files
MEDIA_ROOT=./media

# Lichess Configuration
LICHESS_DOMAIN=https://lichess.org/
LICHESS_NAME=lichess
LICHESS_TOPLEVEL=org
LICHESS_OAUTH_CLIENTID=wucc.palamedes.lichess.app
LICHESS_OAUTH_REDIRECT_SCHEME=https://
LINK_PROTOCOL=http

# Slack Configuration (development placeholders)
SLACK_ANNOUNCE_CHANNEL=
SLACK_TEAM_ID=
CHESSTER_USER_ID=

# Application Configuration
HELTOUR_APP=tournament
HELTOUR_ENV=prod
API_WORKER_HOST=http://apiworker:8000
CELERY_DEFAULT_QUEUE=heltour-{}
JAVAFO_COMMAND=/usr/bin/java -jar ./thirdparty/javafo.jar
DISPLAY_FWCC_BANNER=False

# FWUTCC 2026 banner (shown on the home page)
FWUTCC_BANNER_ENABLED=True
FWUTCC_BANNER_URL=

# Custom theme colors (used by leagues with theme="custom")
# Defaults match the FWUTCC 2026 brand; uncomment to override.
# CUSTOM_THEME_PRIMARY_COLOR=#2d3892
# CUSTOM_THEME_DARK_PRIMARY_COLOR=#1a2466
# CUSTOM_THEME_SECONDARY_COLOR=#5662b5
# CUSTOM_THEME_NAV_FOCUS_COLOR=#3f4ba3
# CUSTOM_THEME_LOGO_URL=/static/tournament/img/fwutcc/logo.png
