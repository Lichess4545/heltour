:80 {
    root * /public

    @notStatic {
        not file {
            try_files {path}
        }
    }

    handle_path /v2/api/* {
        reverse_proxy lichess4545-fidewom-prod_api:8001
    }

    handle /v2/* {
        reverse_proxy lichess4545-fidewom-prod_ui:3000
    }

    handle {
        reverse_proxy @notStatic lichess4545-fidewom-prod_web:8000
        file_server
    }
}
