# Django Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,apiworker,lichess4545.com,www.lichess4545.com,lichess4545.tv,www.lichess4545.tv
CSRF_TRUSTED_ORIGINS=https://lichess4545.com,https://www.lichess4545.com,https://lichess4545.tv,https://www.lichess4545.tv

# Redis Configuration (db 1 for both cache and celery broker, heltour convention)
REDIS_URL=redis://redis:6379/1
BROKER_URL=redis://redis:6379/1

# Email Configuration
# Unverified placeholder carried from litour's stack.env (AWS SES eu-west-3) — confirm
# against heltour's actual mail relay before using this stack for a real deploy.
EMAIL_HOST=email-smtp.eu-west-3.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Application Configuration
HELTOUR_ENV=prod
API_WORKER_HOST=http://apiworker:8000
