{
  "name": "@litour/api-client",
  "version": "0.1.0",
  "description": "Typed client for the Litour FastAPI service.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "generate": "openapi-typescript ../../openapi.json -o src/generated.ts",
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "bundle": "esbuild src/browser.ts --bundle --format=iife --global-name=LitourApi --outfile=dist/litour-api-client.iife.js --minify --target=es2018 --sourcemap",
    "bundle:watch": "esbuild src/browser.ts --bundle --format=iife --global-name=LitourApi --outfile=../../heltour/tournament/static/tournament/js/litour-api-client.iife.js --target=es2018 --sourcemap --watch",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0",
    "partysocket": "^1.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tsconfig/strictest": "^2.0.0",
    "esbuild": "^0.24.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
