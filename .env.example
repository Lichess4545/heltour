SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Carries the django HTTP port, which shifts under devenv when 8000 is taken.
# Local dev via devenv: unset — devenv.nix derives it from the allocated django
# port. Outside devenv (container/prod): set it to the real front-facing origins.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
LINK_PROTOCOL=http

# postgresql://user:password@host:port/dbname
#
# Local dev via devenv: leave these unset. devenv.nix builds DATABASE_URL /
# REDIS_URL / BROKER_URL / EMAIL_HOST / EMAIL_PORT itself from whatever port
# postgres/redis/mailpit actually bound (they shift when the default port is
# taken), and exports them at a priority that wins over anything set here.
# Docker/prod: these are supplied by the container's own env (see
# deploy/prod/compose.yml's DATABASE_URL_FILE / REDIS_URL) — same URL shape,
# different host/port/secret source.
DATABASE_URL=postgresql://user:password@host:port/dbname

# db 1 for both cache and celery broker (heltour convention)
REDIS_URL=redis://host:port/1
BROKER_URL=redis://host:port/1

# Local dev via devenv: EMAIL_HOST/EMAIL_PORT are also devenv-computed (mailpit's
# SMTP port shifts like postgres/redis do); these two are only read outside devenv.
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
SERVER_EMAIL=noreply@lichess.org
DEFAULT_FROM_EMAIL=noreply@lichess.org

LICHESS_DOMAIN=https://lichess.org/
LICHESS_NAME=lichess
LICHESS_TOPLEVEL=org
LICHESS_OAUTH_CLIENTID=heltour
# Must keep the trailing "://" (not just "https")
LICHESS_OAUTH_REDIRECT_SCHEME=https://

# *_FILE_PATH: path to a file holding the secret; app code opens it directly.
# Blank disables the corresponding integration.
GOOGLE_SERVICE_ACCOUNT_KEYFILE_PATH=
SLACK_API_TOKEN_FILE_PATH=
SLACK_CHANNEL_BUILDER_TOKEN_FILE_PATH=
SLACK_WEBHOOK_FILE_PATH=
# raw token, not a file path
SLACK_APP_TOKEN=
LICHESS_API_TOKEN_FILE_PATH=
FCM_API_KEY_FILE_PATH=

SLACK_ANNOUNCE_CHANNEL=C2UP34BCZ
SLACK_TEAM_ID=T0CSGMP0R
CHESSTER_USER_ID=U020MSB1FV0

# or api_worker
HELTOUR_APP=tournament
HELTOUR_ENV=dev
HELTOUR_VERSION=dev
# URL django/celery use to reach the apiworker; carries its HTTP port, which
# shifts under devenv when 8880 is taken. Local dev via devenv: unset — devenv.nix
# derives it from the allocated apiworker port. Outside devenv: set it explicitly.
API_WORKER_HOST=http://localhost:8880
JAVAFO_COMMAND=java -jar ./thirdparty/javafo.jar
# {} is replaced with HELTOUR_ENV, lowercased
CELERY_DEFAULT_QUEUE=heltour-{}
SLEEP_UNIT=1.0
TEAMGEN_PROCESSES_NUMBER=8

# STATIC_ROOT / MEDIA_ROOT deliberately unset: settings.py's own path
# defaults apply. Setting either to a blank value here would override them
# with "" and break collectstatic.
